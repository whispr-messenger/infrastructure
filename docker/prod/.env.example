####################################################################################################
## Shared PostgreSQL
## Single instance — one database per service (created automatically by init-db.sql)
####################################################################################################
POSTGRES_USER=whispr_prod
POSTGRES_PASSWORD=CHANGE_ME

####################################################################################################
## Shared Redis
## Single instance — each service uses a dedicated DB index (0-4)
####################################################################################################
REDIS_PASSWORD=CHANGE_ME

####################################################################################################
## MinIO (object storage for media-service)
####################################################################################################
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

####################################################################################################
## JWT — shared across all NestJS services (auth, user, media, scheduling)
## Generate ECDSA key pair:
##   openssl ecparam -genkey -name prime256v1 -noout -out private-key.pem
##   openssl ec -in private-key.pem -pubout -out public-key.pem
####################################################################################################
JWT_PRIVATE_KEY=CHANGE_ME_ECDSA_PRIVATE_KEY
JWT_PUBLIC_KEY=CHANGE_ME_ECDSA_PUBLIC_KEY
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_VERIFICATION_SECRET=CHANGE_ME

####################################################################################################
## Twilio (auth-service and scheduling-service)
## Obtain credentials at https://console.twilio.com/
####################################################################################################
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1234567890

####################################################################################################
## messaging-service (Elixir/Phoenix)
## SECRET_KEY_BASE must be at least 64 characters:
##   mix phx.gen.secret
## ENCRYPTION_KEY must be exactly 32 characters.
####################################################################################################
MESSAGING_SECRET_KEY_BASE=CHANGE_ME_minimum_64_characters_required_here_use_mix_phx_gen_secret
MESSAGING_ENCRYPTION_KEY=CHANGE_ME_32_char_key_here_xxxxx
MESSAGING_JWT_SECRET=CHANGE_ME

####################################################################################################
## notification-service (Elixir/Phoenix)
## SECRET_KEY_BASE must be at least 64 characters:
##   mix phx.gen.secret
####################################################################################################
NOTIFICATION_SECRET_KEY_BASE=CHANGE_ME_minimum_64_characters_required_here_use_mix_phx_gen_secret
